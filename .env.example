# Cole o conteúdo JSON completo da chave da conta de serviço do Google Cloud
GOOGLE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}

# ID da pasta no Google Drive onde os documentos serão salvos
# Ex: https://drive.google.com/drive/folders/ESTE_ID_AQUI
GOOGLE_DRIVE_FOLDER_ID=sua_pasta_id_aqui

# (Opcional) ID da planilha Google Sheets para registrar os envios
# Ex: https://docs.google.com/spreadsheets/d/ESTE_ID_AQUI/edit
GOOGLE_SHEET_ID=sua_planilha_id_aqui
